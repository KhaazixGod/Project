package com.mycompany.managehospital.Person;
import com.mycompany.managehospital.Person.Person;

public class Employee extends Person{
    private int salary;
    private String Employee_type;
    private String ID_Employee ;
    public Employee(String name,String ID,int age,String ty,int sal)
    {
        super(name,age);
        this.Employee_type = ty;
        this.salary = sal;
        this.ID_Employee = ID;
    }
    public String getID()
    {
        return this.ID_Employee;
    }
    public void setSalary(int sal)
    {
        this.salary = sal;
    }
    public int getSalary()
    {
        return this.salary;
    }
    public void Modify_Employ_type(String ty)
    {
        this.Employee_type = ty;
    }
    public String getPosition()
    {
        return this.Employee_type;
    }
    public void setPosition(String position)
    {
        this.Employee_type = position;
    }
}
